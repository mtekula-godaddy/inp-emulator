# Application Configuration
APP_NAME=inputit-performance-monitor
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# Server Configuration
HOST=localhost
PORT=8000
MCP_SERVER_PORT=3001
LLM_AGENT_URL=http://localhost:11434

# Chrome DevTools MCP Configuration
CHROME_EXECUTABLE_PATH=/usr/bin/google-chrome
CHROME_HEADLESS=true
CHROME_DISABLE_GPU=true
CHROME_NO_SANDBOX=true

# Performance Testing Configuration
MAX_INTERACTIONS_PER_PAGE=10
INTERACTION_DELAY_MIN=500
INTERACTION_DELAY_MAX=2000
PAGE_LOAD_TIMEOUT=30000
ELEMENT_DISCOVERY_TIMEOUT=5000

# Data Storage Configuration
DATA_OUTPUT_DIR=./data
REPORT_FORMAT=json,csv
SCREENSHOT_CAPTURE=true

# LLM Configuration
LLM_MODEL=llama2
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1000
LLM_TIMEOUT=30

# Monitoring and Logging
ENABLE_METRICS=true
METRICS_PORT=9090
LOG_FORMAT=json